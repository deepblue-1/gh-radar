{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "cd .. && pnpm install --frozen-lockfile",
  "buildCommand": "cd .. && pnpm --filter @gh-radar/webapp... build",
  "outputDirectory": ".next",
  "ignoreCommand": "cd .. && git diff --quiet HEAD^ HEAD -- webapp/ packages/shared/ pnpm-lock.yaml"
}
