# ---------------------------------------------------------------------------
# gh-radar webapp — 로컬 환경변수 예시
#
# 이 파일은 템플릿입니다. 실제 값을 채우려면:
#   cp webapp/.env.local.example webapp/.env.local
# `.env.local` 은 `.gitignore` 대상 — 절대 커밋하지 마세요.
#
# 관련 문서: webapp/SETUP.md (Phase 06.2 Auth + Watchlist 운영 셋업)
# ---------------------------------------------------------------------------

# --- Phase 2 Express API (Cloud Run) ---
# Vercel: Production + Preview 양쪽에 동일 값으로 등록 (Phase 4 D-14)
# 로컬: 백엔드 서버를 직접 기동하는 경우 http://localhost:8080
#
# 예시 (Cloud Run):
# NEXT_PUBLIC_API_BASE_URL=https://gh-radar-server-1023658565518.asia-northeast3.run.app
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# --- Phase 06.2 Supabase (Auth + Watchlist 필수) ---
# Supabase Dashboard > Settings > API 에서 확인
# anon public key 만 사용 — service_role key 는 절대 webapp 에 넣지 말 것 (아래 Admin 섹션 참조)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Phase 06.2 Plan 08 E2E 테스트 (Playwright storageState) ---
# scripts/seed-test-user.ts 실행 후 사용 (SETUP.md §5 참조)
# 실제 값은 .env.test.local 또는 CI Secrets 에 보관 — 이 파일에는 빈 값 유지
E2E_TEST_EMAIL=e2e@gh-radar.local
E2E_TEST_PASSWORD=
PLAYWRIGHT_BASE_URL=http://localhost:3000

# --- Admin (E2E 시딩 스크립트 전용, CI Secrets 에만) ---
# ⚠ webapp runtime (dev / build / Vercel) 에는 절대 사용하지 말 것 — RLS 우회 위험.
# 아래 주석을 풀어 쓰는 것은 seed-test-user.ts 같은 신뢰 영역 스크립트 실행 시에만 허용.
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
