{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "pnpm --filter @gh-radar/webapp... build",
  "installCommand": "pnpm install --frozen-lockfile",
  "outputDirectory": "webapp/.next",
  "ignoreCommand": "git diff --quiet HEAD^ HEAD -- webapp/ packages/shared/ pnpm-lock.yaml vercel.json"
}
